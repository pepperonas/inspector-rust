{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClipSnap",
  "version": "0.2.12",
  "identifier": "io.celox.clipsnap",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../../core/frontend/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "popup",
        "title": "ClipSnap",
        "width": 600,
        "height": 500,
        "center": true,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "../../win/src-tauri/icons/32x32.png",
      "../../win/src-tauri/icons/128x128.png",
      "../../win/src-tauri/icons/128x128@2x.png",
      "../../win/src-tauri/icons/icon.icns",
      "../../win/src-tauri/icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "entitlements.plist"
    },
    "copyright": "© 2026 Martin Pfeffer | celox.io",
    "shortDescription": "Lightweight clipboard history manager for macOS",
    "longDescription": "ClipSnap is a fast, lightweight clipboard history manager for macOS. Press Ctrl+Shift+V to browse, search, and paste anything you've recently copied."
  }
}
