{
  "identifier": "default",
  "description": "Capability for the Inspector Rust popup window",
  "windows": ["popup", "screenshot-preview", "screenshot-editor"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "core:window:allow-set-position",
    "core:window:allow-start-dragging",
    "core:event:default",
    "core:app:default",
    "clipboard-manager:default",
    "clipboard-manager:allow-write-text",
    "opener:default",
    "dialog:allow-open",
    "dialog:allow-save"
  ]
}
